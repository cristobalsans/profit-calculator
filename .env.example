# ── TIENDA 1 ──────────────────────────────────────────────────────
# Reemplaza TIENDA1 con el ID de tu tienda en mayúsculas (ej: si id="mi_tienda" → MI_TIENDA)

TIENDA1_SHOPIFY_STORE=nombre-de-tu-tienda
TIENDA1_SHOPIFY_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxx
TIENDA1_META_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxxxx
TIENDA1_META_AD_ACCOUNT_ID=123456789
TIENDA1_META_APP_ID=123456789012345
TIENDA1_META_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── TIENDA 2 ──────────────────────────────────────────────────────

TIENDA2_SHOPIFY_STORE=nombre-de-tu-segunda-tienda
TIENDA2_SHOPIFY_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxx
TIENDA2_META_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxxxx
TIENDA2_META_AD_ACCOUNT_ID=987654321
TIENDA2_META_APP_ID=123456789012345
TIENDA2_META_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── PUERTO (Railway lo pone automáticamente) ───────────────────────
PORT=3000
